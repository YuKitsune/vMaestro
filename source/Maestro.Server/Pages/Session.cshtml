@page
@model SessionModel
@{
    ViewData["Title"] = $"{Model.Airport} - {Model.Partition}";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="bg-dark border-bottom px-3 py-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Index">Sessions</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Partition / @Model.Airport</li>
        </ol>
    </nav>
}

<h1>@Model.Airport <small class="text-secondary">@Model.Partition</small></h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header">Current Runway Mode</div>
            <div class="card-body">
                <h5 class="card-title">@Model.Session!.Sequence.CurrentRunwayMode.Identifier</h5>
                <table class="table table-dark table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Runway</th>
                            <th>Rate (sec)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var runway in Model.Session.Sequence.CurrentRunwayMode.Runways)
                        {
                            <tr>
                                <td>@runway.Identifier</td>
                                <td>@runway.AcceptanceRateSeconds</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Session.Sequence.NextRunwayMode is not null)
        {
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header">Next Runway Mode</div>
                <div class="card-body">
                    <h5 class="card-title">@Model.Session.Sequence.NextRunwayMode.Identifier</h5>
                    <table class="table table-dark table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Runway</th>
                                <th>Rate (sec)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var runway in Model.Session.Sequence.NextRunwayMode.Runways)
                            {
                                <tr>
                                    <td>@runway.Identifier</td>
                                    <td>@runway.AcceptanceRateSeconds</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card bg-dark border-secondary">
            <div class="card-header">Connected Controllers</div>
            <div class="card-body">
                @if (Model.Connections.Length == 0)
                {
                    <p class="text-secondary mb-0">No controllers connected.</p>
                }
                else
                {
                    <table class="table table-dark table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Callsign</th>
                                <th>Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in Model.Connections)
                            {
                                <tr>
                                    <td>@connection.Callsign</td>
                                    <td>
                                        <span class="badge @FormatHelpers.GetRoleBadgeClass(connection.Role)">
                                            @connection.Role
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card bg-dark border-secondary">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Flights</span>
                <span class="text-secondary">@Model.TotalFlights total</span>
            </div>
            <div class="card-body">
                @if (Model.PagedFlights.Length == 0)
                {
                    <p class="text-secondary mb-0">No flights in sequence.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Callsign</th>
                                    <th>Runway</th>
                                    <th>State</th>
                                    <th>STA</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var flight in Model.PagedFlights)
                                {
                                    <tr>
                                        <td>
                                            <a asp-page="/Flight"
                                               asp-route-partition="@Model.Partition"
                                               asp-route-airport="@Model.Airport"
                                               asp-route-callsign="@flight.Callsign"
                                               class="text-light text-decoration-none">
                                                @flight.Callsign
                                            </a>
                                        </td>
                                        <td>@flight.AssignedRunwayIdentifier</td>
                                        <td>
                                            <span class="badge @FormatHelpers.GetStateBadgeClass(flight.State)">
                                                @flight.State
                                            </span>
                                        </td>
                                        <td>@FormatHelpers.ToDDHHMM(flight.LandingTime)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Flight pagination" class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-page="/Session"
                                       asp-route-partition="@Model.Partition"
                                       asp-route-airport="@Model.Airport"
                                       asp-route-page="@(Model.Page - 1)">
                                        Previous
                                    </a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.Page ? "active" : "")">
                                        <a class="page-link"
                                           asp-page="/Session"
                                           asp-route-partition="@Model.Partition"
                                           asp-route-airport="@Model.Airport"
                                           asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }
                                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-page="/Session"
                                       asp-route-partition="@Model.Partition"
                                       asp-route-airport="@Model.Airport"
                                       asp-route-page="@(Model.Page + 1)">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>
