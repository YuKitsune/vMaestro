@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Sessions</h1>

@if (!Model.Sessions.Any())
{
    <div class="alert alert-secondary" role="alert">
        No active sessions.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Environment</th>
                    <th>Airport</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model.Sessions)
                {
                    <tr>
                        <td>
                            <a href="/dashboard/session?environment=@session.Environment&airport=@session.AirportIdentifier">
                                @session.Environment
                            </a>
                        </td>
                        <td>
                            <a href="/dashboard/session?environment=@session.Environment&airport=@session.AirportIdentifier">
                                @session.AirportIdentifier
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
