@page
@model FlightModel
@{
    ViewData["Title"] = Model.Callsign;
    var flight = Model.Flight!;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="bg-dark border-bottom px-3 py-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Index">Sessions</a></li>
            <li class="breadcrumb-item">
                <a asp-page="/Session"
                   asp-route-partition="@Model.Partition"
                   asp-route-airport="@Model.Airport">
                    @Model.Partition / @Model.Airport
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Callsign</li>
        </ol>
    </nav>
}

<h1>@flight.Callsign <span class="badge @FormatHelpers.GetStateBadgeClass(flight.State)">@flight.State</span></h1>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header">Flight Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Callsign</dt>
                    <dd class="col-sm-7">@flight.Callsign</dd>

                    <dt class="col-sm-5">Aircraft Type</dt>
                    <dd class="col-sm-7">@flight.AircraftType</dd>

                    <dt class="col-sm-5">Wake Category</dt>
                    <dd class="col-sm-7">@flight.WakeCategory</dd>

                    <dt class="col-sm-5">Aircraft Category</dt>
                    <dd class="col-sm-7">@flight.AircraftCategory</dd>

                    <dt class="col-sm-5">Origin</dt>
                    <dd class="col-sm-7">@(flight.OriginIdentifier ?? "-")</dd>

                    <dt class="col-sm-5">Destination</dt>
                    <dd class="col-sm-7">@flight.DestinationIdentifier</dd>

                    <dt class="col-sm-5">From Departure Airport</dt>
                    <dd class="col-sm-7">@(flight.IsFromDepartureAirport ? "Yes" : "No")</dd>

                    <dt class="col-sm-5">High Priority</dt>
                    <dd class="col-sm-7">@(flight.HighPriority ? "Yes" : "No")</dd>

                    <dt class="col-sm-5">Manually Inserted</dt>
                    <dd class="col-sm-7">@(flight.IsManuallyInserted ? "Yes" : "No")</dd>
                </dl>
            </div>
        </div>

        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header">Sequence Information</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">State</dt>
                    <dd class="col-sm-7">
                        <span class="badge @FormatHelpers.GetStateBadgeClass(flight.State)">@flight.State</span>
                    </dd>

                    <dt class="col-sm-5">Number in Sequence</dt>
                    <dd class="col-sm-7">@flight.NumberInSequence</dd>

                    <dt class="col-sm-5">Assigned Runway</dt>
                    <dd class="col-sm-7">@flight.AssignedRunwayIdentifier</dd>

                    <dt class="col-sm-5">Number to Land on Runway</dt>
                    <dd class="col-sm-7">@flight.NumberToLandOnRunway</dd>

                    <dt class="col-sm-5">Approach Type</dt>
                    <dd class="col-sm-7">@(string.IsNullOrEmpty(flight.ApproachType) ? "-" : flight.ApproachType)</dd>

                    <dt class="col-sm-5">Feeder Fix</dt>
                    <dd class="col-sm-7">@(flight.FeederFixIdentifier ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header">Delays</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Initial Delay</dt>
                    <dd class="col-sm-7">@FormatTimeSpan(flight.InitialDelay)</dd>

                    <dt class="col-sm-5">Remaining Delay</dt>
                    <dd class="col-sm-7">@FormatTimeSpan(flight.RemainingDelay)</dd>

                    <dt class="col-sm-5">Maximum Delay</dt>
                    <dd class="col-sm-7">@(flight.MaximumDelay.HasValue ? FormatTimeSpan(flight.MaximumDelay.Value) : "-")</dd>

                    <dt class="col-sm-5">Flow Controls</dt>
                    <dd class="col-sm-7">@flight.FlowControls</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header">Times</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Activated Time</dt>
                    <dd class="col-sm-7">@FormatTime(flight.ActivatedTime)</dd>

                    <dt class="col-sm-5">Estimated Departure</dt>
                    <dd class="col-sm-7">@FormatTime(flight.EstimatedDepartureTime)</dd>

                    <dt class="col-sm-5">Initial Feeder Fix Estimate</dt>
                    <dd class="col-sm-7">@FormatTime(flight.InitialFeederFixEstimate)</dd>

                    <dt class="col-sm-5">Feeder Fix Estimate</dt>
                    <dd class="col-sm-7">@FormatTime(flight.FeederFixEstimate) @(flight.ManualFeederFixEstimate ? "(Manual)" : "")</dd>

                    <dt class="col-sm-5">Feeder Fix Time (STA)</dt>
                    <dd class="col-sm-7">@FormatTime(flight.FeederFixTime)</dd>

                    <dt class="col-sm-5">Actual Feeder Fix Time</dt>
                    <dd class="col-sm-7">@FormatTime(flight.ActualFeederFixTime)</dd>

                    <dt class="col-sm-5">Initial Landing Estimate</dt>
                    <dd class="col-sm-7">@FormatHelpers.ToDDHHMM(flight.InitialLandingEstimate)</dd>

                    <dt class="col-sm-5">Landing Estimate</dt>
                    <dd class="col-sm-7">@FormatHelpers.ToDDHHMM(flight.LandingEstimate)</dd>

                    <dt class="col-sm-5">Target Landing Time</dt>
                    <dd class="col-sm-7">@FormatTime(flight.TargetLandingTime)</dd>

                    <dt class="col-sm-5">Landing Time (STA)</dt>
                    <dd class="col-sm-7">@FormatHelpers.ToDDHHMM(flight.LandingTime)</dd>

                    <dt class="col-sm-5">Time to Go</dt>
                    <dd class="col-sm-7">@(flight.TimeToGo.HasValue ? FormatTimeSpan(flight.TimeToGo.Value) : "-")</dd>

                    <dt class="col-sm-5">Last Seen</dt>
                    <dd class="col-sm-7">@FormatHelpers.ToDDHHMM(flight.LastSeen)</dd>
                </dl>
            </div>
        </div>

        @if (flight.Position is not null)
        {
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header">Position</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Latitude</dt>
                        <dd class="col-sm-7">@flight.Position.Coordinate.Latitude.ToString("F4")</dd>

                        <dt class="col-sm-5">Longitude</dt>
                        <dd class="col-sm-7">@flight.Position.Coordinate.Longitude.ToString("F4")</dd>

                        <dt class="col-sm-5">Altitude</dt>
                        <dd class="col-sm-7">@flight.Position.Altitude ft</dd>

                        <dt class="col-sm-5">Ground Speed</dt>
                        <dd class="col-sm-7">@flight.Position.GroundSpeed kts</dd>
                    </dl>
                </div>
            </div>
        }

        @if (flight.Fixes.Length > 0)
        {
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header">Route Fixes</div>
                <div class="card-body">
                    <table class="table table-dark table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Fix</th>
                                <th>Estimate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fix in flight.Fixes)
                            {
                                <tr>
                                    <td>@fix.FixIdentifier</td>
                                    <td>@FormatHelpers.ToDDHHMM(fix.Estimate)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    string FormatTime(DateTimeOffset? time)
    {
        return time.HasValue ? FormatHelpers.ToDDHHMM(time.Value) : "-";
    }

    string FormatTimeSpan(TimeSpan span)
    {
        if (span == TimeSpan.Zero)
            return "0";
        return $"{(int)span.TotalMinutes}:{span.Seconds:D2}";
    }
}
