@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Active Sessions</h1>

@if (!Model.Sessions.Any())
{
    <div class="alert alert-secondary" role="alert">
        No active sessions.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover">
            <thead>
                <tr>
                    <th>Partition</th>
                    <th>Airport</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model.Sessions)
                {
                    <tr>
                        <td>@session.Partition</td>
                        <td>@session.AirportIdentifier</td>
                        <td>
                            <a asp-page="/Session"
                               asp-route-partition="@session.Partition"
                               asp-route-airport="@session.AirportIdentifier"
                               class="btn btn-sm btn-outline-light">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
