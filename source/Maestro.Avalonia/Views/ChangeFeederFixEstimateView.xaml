<UserControl x:Class="Maestro.Avalonia.Views.ChangeFeederFixEstimateView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Maestro.Avalonia"
             xmlns:viewModels="clr-namespace:Maestro.Avalonia.ViewModels"
             xmlns:controls="clr-namespace:Maestro.Avalonia.Controls"
             xmlns:converters="clr-namespace:Maestro.Avalonia.Converters"
             Background="{x:Static local:Theme.BackgroundColor}"
             Padding="8"
             Width="320"
             Height="140">
    <UserControl.Styles>
        <StyleInclude Source="avares://Maestro.Avalonia/Styles.xaml"/>
        <Style Selector="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Width" Value="64" />
        </Style>
    </UserControl.Styles>
    <UserControl.Resources>
        <converters:TimeConverter x:Key="TimeConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Flight"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Callsign}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Feeder Fix"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FeederFix}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Original ETA_FF"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OriginalFeederFixEstimate, Converter={StaticResource TimeConverter}}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="New ETA_FF"/>
            <controls:TimeControl Grid.Row="3" Grid.Column="1" Time="{Binding NewFeederFixEstimate}" MaxHeight="20" />

        </Grid>

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="OK" Command="{Binding ChangeFeederFixEstimateCommand}"/>
            <Button Grid.Column="3" Content="Cancel" Command="{Binding CloseWindowCommand}"/>
        </Grid>
    </Grid>
</UserControl>
