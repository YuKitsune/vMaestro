<UserControl x:Class="Maestro.Avalonia.Views.ConnectionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Maestro.Avalonia"
             xmlns:viewModels="clr-namespace:Maestro.Avalonia.ViewModels"
             xmlns:controls="clr-namespace:Maestro.Avalonia.Controls"
             Background="{x:Static local:Theme.BackgroundColor}"
             Padding="8"
             Width="240">
    <UserControl.Styles>
        <StyleInclude Source="avares://Maestro.Avalonia/Styles.xaml"/>
        <Style Selector="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Width" Value="64" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">

        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
              ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server"/>
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                ItemsSource="{Binding Servers}"
                SelectedValue="{Binding SelectedServer, Mode=TwoWay}"
                IsEnabled="{Binding CanChangeServer}"
                Margin="0,2,0,2" />

        </Grid>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
              ColumnDefinitions="*,Auto,*,Auto,*">

            <Button Grid.Column="1" Content="{Binding ConnectButtonText}" Command="{Binding ConnectOrDisconnectCommand}"/>
            <Button Grid.Column="3" Content="Cancel" Command="{Binding CloseWindowCommand}"/>
        </Grid>

    </Grid>
</UserControl>
