<UserControl x:Class="Maestro.Avalonia.Views.CoordinationView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Maestro.Avalonia"
             xmlns:viewModels="clr-namespace:Maestro.Avalonia.ViewModels"
             Background="{x:Static local:Theme.BackgroundColor}"
             Padding="8"
             MinWidth="400"
             Height="240">
    <UserControl.Styles>
        <StyleInclude Source="avares://Maestro.Avalonia/Styles.xaml"/>
        <Style Selector="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Width" Value="80" />
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{x:Static local:Theme.SelectedButtonColor}"/>
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{x:Static local:Theme.BackgroundColor}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">

        <ListBox
            Grid.Row="0"
            ItemsSource="{Binding Messages}"
            SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
            BorderThickness="0"
            Background="Transparent"
            Margin="2">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
            <Grid IsVisible="{Binding ShowDestinationSelector}">
                <ComboBox
                    Width="104"
                    Height="18"
                    ItemsSource="{Binding Destinations}"
                    SelectedItem="{Binding SelectedDestination, Mode=TwoWay}"
                    SelectionChanged="Destination_OnSelectionChanged"/>
                <TextBlock
                    Text="DESTINATION"
                    IsHitTestVisible="False"
                    TextAlignment="Center"/>
            </Grid>
            <Button Content="SEND" Command="{Binding SendCommand}" IsVisible="{Binding ShowSendButton}"/>
            <Button Content="CANCEL" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
