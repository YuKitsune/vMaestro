<UserControl x:Class="Maestro.Wpf.Views.WindView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Maestro.Wpf"
             xmlns:controls="clr-namespace:Maestro.Wpf.Controls"
             xmlns:viewModels="clr-namespace:Maestro.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:WindViewModel}"
             mc:Ignorable="d"
             Background="{x:Static local:Theme.BackgroundColor}"
             MinWidth="440"
             Height="Auto"
             Padding="8">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Maestro.Wpf;component/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource GenericTextStyle}" />
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonBaseStyle}" />

        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Orientation="Vertical">

        <TextBlock>
            <Run Text="Wind at "/>
            <Run Text="{Binding UpperWindAltitude}"/>
            <Run Text=" feet"/>
        </TextBlock>

        <controls:BeveledBorder BorderThickness="{x:Static local:Theme.BeveledBorderThickness}" BevelType="Sunken">
            <Border Padding="4">
                <StackPanel Orientation="Vertical">
                    <Slider Value="{Binding UpperWindSpeed}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="true"
                            Minimum="0"
                            Maximum="200"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Speed"/>
                        <TextBlock Text=": "/>
                        <TextBlock Text="{Binding UpperWindSpeed}" Padding="4,0,2,0"/>
                        <TextBlock Text=" kts"/>
                    </StackPanel>

                    <Border Padding="4" />

                    <Slider Value="{Binding UpperWindDirection}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="true"
                            Minimum="0"
                            Maximum="360"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Direction"/>
                        <TextBlock Text=": "/>
                        <TextBlock Text="{Binding UpperWindDirection}" Padding="4,0,2,0"/>
                        <TextBlock Text=" deg"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </controls:BeveledBorder>

        <Border Padding="8" />

        <TextBlock Text="Surface wind"/>

        <controls:BeveledBorder BorderThickness="{x:Static local:Theme.BeveledBorderThickness}" BevelType="Sunken">
            <Border Padding="4">
                <StackPanel Orientation="Vertical">
                    <Slider Value="{Binding SurfaceWindSpeed}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="true"
                            Minimum="0"
                            Maximum="200"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Speed"/>
                        <TextBlock Text=": "/>
                        <TextBlock Text="{Binding SurfaceWindSpeed}" Padding="4,0,2,0"/>
                        <TextBlock Text=" kts"/>
                    </StackPanel>

                    <Border Padding="4" />

                    <Slider Value="{Binding SurfaceWindDirection}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="true"
                            Minimum="0"
                            Maximum="360"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Direction"/>
                        <TextBlock Text=": "/>
                        <TextBlock Text="{Binding SurfaceWindDirection}" Padding="4,0,2,0"/>
                        <TextBlock Text=" deg"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </controls:BeveledBorder>

        <Border Padding="4" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Width="56" Command="{Binding ChangeWindCommand}">Ok</Button>
            <Button Grid.Column="1" Width="56" Command="{Binding CloseWindowCommand}">Cancel</Button>
        </Grid>

    </StackPanel>
</UserControl>

